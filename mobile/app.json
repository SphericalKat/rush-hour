{
  "expo": {
    "name": "Rush Hour",
    "slug": "rush-hour",
    "version": "0.5.1",
    "scheme": "rush-hour",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFD900"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.sphericalkat.rushhour"
    },
    "android": {
      "package": "com.sphericalkat.rushhour",
      "versionCode": 3,
      "adaptiveIcon": {
        "backgroundColor": "#FFD900",
        "foregroundImage": "./assets/icon.png",
        "backgroundImage": "./assets/icon-bg.png",
        "monochromeImage": "./assets/icon.png"
      },
      "predictiveBackGestureEnabled": true,
      "permissions": [
        "RECEIVE_BOOT_COMPLETED"
      ]
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Rush Hour uses your location to share live train position with other commuters.",
          "locationAlwaysAndWhenInUsePermission": "Rush Hour uses your location in the background to keep sharing live train position while your phone is in your pocket.",
          "isAndroidBackgroundLocationEnabled": true,
          "isAndroidForegroundServiceEnabled": true
        }
      ],
      "expo-system-ui",
      [
        "expo-font",
        {
          "android": {
            "fonts": [
              {
                "fontFamily": "DMSans",
                "fontDefinitions": [
                  {
                    "path": "node_modules/@expo-google-fonts/dm-sans/400Regular/DMSans_400Regular.ttf",
                    "weight": 400
                  },
                  {
                    "path": "node_modules/@expo-google-fonts/dm-sans/500Medium/DMSans_500Medium.ttf",
                    "weight": 500
                  },
                  {
                    "path": "node_modules/@expo-google-fonts/dm-sans/600SemiBold/DMSans_600SemiBold.ttf",
                    "weight": 600
                  },
                  {
                    "path": "node_modules/@expo-google-fonts/dm-sans/700Bold/DMSans_700Bold.ttf",
                    "weight": 700
                  }
                ]
              }
            ]
          },
          "ios": {
            "fonts": [
              "node_modules/@expo-google-fonts/dm-sans/400Regular/DMSans_400Regular.ttf",
              "node_modules/@expo-google-fonts/dm-sans/500Medium/DMSans_500Medium.ttf",
              "node_modules/@expo-google-fonts/dm-sans/600SemiBold/DMSans_600SemiBold.ttf",
              "node_modules/@expo-google-fonts/dm-sans/700Bold/DMSans_700Bold.ttf"
            ]
          }
        }
      ],
      "expo-notifications",
      "expo-splash-screen",
      "expo-sqlite",
      "./plugins/android-signing",
      "./plugins/android-abi-splits",
      "./plugins/android-flavors",
      "expo-background-task",
      "react-native-legal"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
